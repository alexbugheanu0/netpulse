# NetPulse environment variables
# Copy this file to .env and fill in your lab values.
# Never commit .env to version control.

NETPULSE_USERNAME=admin
NETPULSE_PASSWORD=your_ssh_password_here
NETPULSE_SECRET=your_enable_secret_here

# SSH connection + command timeout in seconds.
# 10-15s is sufficient for most lab switches (prompt appears in <2s).
# Raise to 20-30 only if devices are slow or across a high-latency WAN.
NETPULSE_SSH_TIMEOUT=15

NETPULSE_SSH_PORT=22

# Maximum concurrent SSH threads for multi-device jobs (scope=all / scope=role).
# Increase for large inventories; decrease if the network cannot handle burst connections.
NETPULSE_SSH_WORKERS=10
